{
  "model": "opus[1m]",
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git blame:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh api:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform show:*)",
      "Bash(terraform state list:*)",
      "Bash(terraform state show:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(aws sts get-caller-identity)",
      "Bash(aws sqs list-queues:*)",
      "Bash(aws sqs get-queue-attributes:*)",
      "Bash(aws sns list-topics:*)",
      "Bash(aws sns list-subscriptions:*)",
      "Bash(aws cloudwatch describe-alarms:*)",
      "Bash(aws logs describe-log-groups:*)",
      "Bash(aws logs filter-log-events:*)",
      "Bash(uv run pytest:*)",
      "Bash(pytest:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run:*)",
      "Bash(yarn test:*)",
      "Bash(yarn run:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)",
      "Bash(make test:*)",
      "Bash(make lint:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)"
    ],
    "deny": [
      "Bash(aws secretsmanager:*)",
      "Bash(aws ssm get-parameter:*)",
      "Bash(gcloud secrets:*)",
      "Bash(vault:*)",
      "Bash(kubectl get secret:*)",
      "Bash(kubectl create secret:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
